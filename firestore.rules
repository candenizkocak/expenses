rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function role() {
      return signedIn() && userDoc(request.auth.uid).data.role;
    }

    match /users/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || role() == "manager" || role() == "admin");
      allow write: if role() == "admin";
    }

    match /rfidCards/{cardId} {
      allow read, write: if role() == "admin";
    }

    match /expenses/{expenseId} {
      allow create: if signedIn()
        && request.resource.data.employeeId == request.auth.uid
        && request.resource.data.status == "pending";

      allow read: if signedIn()
        && (resource.data.employeeId == request.auth.uid
          || resource.data.managerId == request.auth.uid
          || role() == "admin");

      allow update: if signedIn()
        && (role() == "admin"
          || (resource.data.managerId == request.auth.uid
            && request.resource.data.managerId == resource.data.managerId
            && request.resource.data.employeeId == resource.data.employeeId
            && request.resource.data.imageUrl == resource.data.imageUrl
            && request.resource.data.diff(resource.data).changedKeys().hasOnly([
              "status",
              "reviewedAt",
              "reviewedBy",
              "rejectionReason",
              "plannedPaymentDate",
              "updatedAt"
            ])));
    }
  }
}
