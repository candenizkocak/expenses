rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function role() {
      return signedIn() ? userDoc(request.auth.uid).data.role : null;
    }

    match /users/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || role() == "manager" || role() == "admin");
      allow write: if role() == "admin";
    }

    match /rfidCards/{cardId} {
      allow read: if signedIn();
      allow write: if role() == "admin";
    }

    match /expenses/{expenseId} {
      allow read, create, update: if signedIn();
    }
  }
}
